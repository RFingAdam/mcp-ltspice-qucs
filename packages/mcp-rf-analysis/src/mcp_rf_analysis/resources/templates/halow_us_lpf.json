    {"freq": 1575.42e6, "rejection_min_db": 30, "label": "GPS L1 protection"},
    {"freq": 1730e6,    "rejection_min_db": 55, "label": "EU 2f0 (LTE B3 UL collision)"},
    {"freq": 1853e6,    "rejection_min_db": 55, "label": "NA 2f0 (LTE B25 DL collision)"},
    {"freq": 2400e6,    "rejection_min_db": 30, "label": "ISM 2.4 GHz low edge (BLE/WiFi)"},
    {"freq": 2484e6,    "rejection_min_db": 30, "label": "ISM 2.4 GHz high edge"},
    {"freq": 2780e6,    "rejection_min_db": 40, "label": "NA 3f0 (LTE B7/B41)"}
  ]
}
